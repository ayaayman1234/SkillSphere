@model IEnumerable<SkillSphere.Models.SwapRequest>

<link rel="stylesheet" href="~/css/site.css" />

<div class="skills-page">
    <div class="container">

        <div class="skills-header text-center">
            <span class="skills-tag">Swap Requests</span>
            <h1 class="skills-main-title">My Requests</h1>
            <p class="skills-subtitle">Manage your skill exchange requests.</p>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-arrow-right-arrow-left" style="font-size:4rem; color:#dbeafe;"></i>
                <h3 class="mt-4" style="color:#94a3b8;">No requests yet</h3>
            </div>
        }
        else
        {
            <div class="messages-list">
                @foreach (var item in Model)
                {
                    <div class="message-card">
                        <div class="message-top">
                            <div class="message-user">
                                <i class="fa-solid fa-arrow-right-arrow-left"></i>
                            </div>
                            <span class="request-status @(item.Status == "Pending" ? "status-pending" : item.Status == "Accepted" ? "status-accepted" : "status-rejected")">
                                @item.Status
                            </span>
                        </div>

                        <div class="message-content">
                            <p><b>From:</b> @(item.FromUser?.FullName ?? item.FromUserId)</p>
                            <p><b>To:</b> @(item.ToUser?.FullName ?? item.ToUserId)</p>
                        </div>

                        @if (User.IsInRole("Admin") && item.Status == "Pending")
                        {
                            <div class="skill-actions mt-3">
                                <form asp-controller="SwapRequests"
                                      asp-action="Accept"
                                      method="post"
                                      style="flex:1;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="skill-btn details-btn w-100">
                                        <i class="fa-solid fa-check me-1"></i> Accept
                                    </button>
                                </form>
                                <form asp-controller="SwapRequests"
                                      asp-action="Reject"
                                      method="post"
                                      style="flex:1;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="skill-btn delete-btn w-100">
                                        <i class="fa-solid fa-x me-1"></i> Reject
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        }

    </div>
</div>