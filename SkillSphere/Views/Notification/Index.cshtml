@model IEnumerable<SkillSphere.Models.Message>

@{
    ViewData["Title"] = "Messages";
}

<div class="skills-page">

    <div class="container">

        <div class="skills-header text-center">
            <span class="skills-tag">Inbox</span>

            <h1 class="skills-main-title">
                Messages
            </h1>

            <p class="skills-subtitle">
                Stay connected with your community.
            </p>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-box text-center">

                <i class="fa-regular fa-envelope-open empty-icon"></i>

                <h2>No messages yet</h2>

                <p>
                    Your conversations will appear here.
                </p>

            </div>
        }
        else
        {
            <div class="row g-4">

                @foreach (var item in Model)
                {
                    <div class="col-lg-6">

                        <div class="message-card">

                            <div class="message-top">
                                <h4>@item.Content</h4>

                                <span>
                                    @item.SentAt.ToShortDateString()
                                </span>
                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>

</div>