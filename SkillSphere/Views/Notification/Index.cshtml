@model IEnumerable<SkillSphere.Models.Notification>

@{
    ViewData["Title"] = "Notifications";
}

<div class="skills-page">

    <div class="container">

        <div class="skills-header text-center">

            <span class="skills-tag">Notifications</span>

            <h1 class="skills-main-title">
                Notifications
            </h1>

            <p class="skills-subtitle">
                Stay updated with your account activity.
            </p>

        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-box text-center">

                <i class="fa-regular fa-bell empty-icon"></i>

                <h2>No notifications yet</h2>

                <p>
                    You will see updates here when something happens.
                </p>

            </div>
        }
        else
        {
            <div class="row g-4">

                @foreach (var item in Model)
                {
                    <div class="col-lg-6">

                        <div class="message-card">

                            <div class="message-top">

                                <h4>@item.Text</h4>

                                <span>
                                    @item.CreatedAt.ToShortDateString()
                                </span>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>

</div>