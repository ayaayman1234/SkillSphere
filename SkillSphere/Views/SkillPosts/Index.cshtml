@model IEnumerable<SkillSphere.Models.SkillPost>
@using System.Linq

@{
    ViewData["Title"] = "Skills Feed";
    bool isAdmin = User.IsInRole("Admin");
}

<link rel="stylesheet" href="~/css/site.css" />

@Html.AntiForgeryToken()

<div class="skills-page">
    <div class="container">

        <div class="skills-header text-center">
            <span class="skills-tag">Discover Skills</span>
            <h1 class="skills-main-title">Skills Feed</h1>
            <p class="skills-subtitle">Learn, Teach & Grow Together 🚀</p>
        </div>

        <form method="get" class="row g-3 mb-5 justify-content-center">
            <div class="col-md-5">
                <div class="search-wrapper">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input type="text"
                           id="liveSearch"
                           name="search"
                           value="@ViewBag.CurrentSearch"
                           class="form-control search-input"
                           placeholder="Search skills..." />
                </div>
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select search-input">
                    <option value="">All Categories</option>
                    @if (ViewBag.CurrentCategory == "Programming")
                    {
                        <option value="Programming" selected>Programming</option>
                    }
                    else
                    {
                        <option value="Programming">Programming</option>
                    }
                    @if (ViewBag.CurrentCategory == "Design")
                    {
                        <option value="Design" selected>Design</option>
                    }
                    else
                    {
                        <option value="Design">Design</option>
                    }
                    @if (ViewBag.CurrentCategory == "Marketing")
                    {
                        <option value="Marketing" selected>Marketing</option>
                    }
                    else
                    {
                        <option value="Marketing">Marketing</option>
                    }
                    @if (ViewBag.CurrentCategory == "AI")
                    {
                        <option value="AI" selected>AI</option>
                    }
                    else
                    {
                        <option value="AI">AI</option>
                    }
                    @if (ViewBag.CurrentCategory == "Business")
                    {
                        <option value="Business" selected>Business</option>
                    }
                    else
                    {
                        <option value="Business">Business</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="type" class="form-select search-input">
                    <option value="">All Types</option>
                    @if (ViewBag.CurrentType == "Learning")
                    {
                        <option value="Learning" selected>Learning</option>
                    }
                    else
                    {
                        <option value="Learning">Learning</option>
                    }
                    @if (ViewBag.CurrentType == "Teaching")
                    {
                        <option value="Teaching" selected>Teaching</option>
                    }
                    else
                    {
                        <option value="Teaching">Teaching</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn-main w-100 search-btn">Search</button>
            </div>
        </form>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-magnifying-glass" style="font-size:4rem; color:#dbeafe;"></i>
                <h3 class="mt-4" style="color:#94a3b8;">No Skills Found</h3>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6 skill-item" id="skill-@item.Id">
                        <div class="skill-card-new">

                            <div class="skill-card-top">
                                <div class="skill-icon-box">
                                    @if (item.Category == "Programming")
                                    {
                                        <i class="fa-solid fa-code"></i>
                                    }
                                    else if (item.Category == "Design")
                                    {
                                        <i class="fa-solid fa-palette"></i>
                                    }
                                    else if (item.Category == "Marketing")
                                    {
                                        <i class="fa-solid fa-bullhorn"></i>
                                    }
                                    else if (item.Category == "AI")
                                    {
                                        <i class="fa-solid fa-robot"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-briefcase"></i>
                                    }
                                </div>
                                <span class="skill-date">
                                    @item.CreatedAt.ToShortDateString()
                                </span>
                            </div>

                            <div class="mb-3">
                                <span class="category-badge">@item.Category</span>
                                <span class="type-badge ms-1">@item.Type</span>
                            </div>

                            <h3 class="skill-name">@item.Title</h3>
                            <p class="skill-description">@item.Description</p>

                            <div class="offer-section">
                                <span class="offer-label">Offers in Exchange</span>
                                <p class="offer-text">@item.Offer</p>
                            </div>

                            <div class="skill-actions">
                                @if (isAdmin)
                                {
                                    <a asp-action="Create" class="skill-btn create-btn flex-fill text-center">
                                        <i class="fa-solid fa-plus me-1"></i> Create
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="skill-btn edit-btn flex-fill text-center">
                                        Edit
                                    </a>

                                    <button class="skill-btn delete-btn deleteBtn flex-fill">
                                        Delete
                                    </button>
                                }
                                <div class="skill-actions">
    
                                    <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="skill-btn btn-details">
                                        <i class="fa-solid fa-circle-info"></i>
                                        Details
                                    </a>

                                    <form asp-controller="SwapRequests"
                                          asp-action="Send"
                                          method="post"
                                          class="w-100">

                                        <input type="hidden" name="toUserId" value="@item.UserId" />

                                        <button type="submit" class="skill-btn btn-request">
                                            <i class="fa-solid fa-paper-plane"></i>
                                            Request
                                        </button>

                                    </form>

                                </div>
                            </div>

                        </div>
                    </div>
                }
            </div>

            <div class="pagination-wrapper">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@ViewBag.CurrentSearch"
                           asp-route-category="@ViewBag.CurrentCategory"
                           asp-route-type="@ViewBag.CurrentType"
                           class="page-btn @(ViewBag.CurrentPage == i ? "active-page" : "")">
                        @i
                    </a>
                }
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        // ===== LIVE SEARCH =====
        document.getElementById('liveSearch').addEventListener('input', function () {
            const val = this.value.toLowerCase();
            document.querySelectorAll('.skill-item').forEach(card => {
                const title = card.querySelector('.skill-name').textContent.toLowerCase();
                const desc = card.querySelector('.skill-description').textContent.toLowerCase();
                card.style.display = (title.includes(val) || desc.includes(val)) ? '' : 'none';
            });
        });

        // ===== DELETE AJAX =====
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        document.querySelectorAll(".deleteBtn").forEach(btn => {
            btn.addEventListener("click", function () {
                let id = this.getAttribute("data-id");
                if (!confirm("Are you sure you want to delete this skill?")) return;

                fetch("/SkillPosts/DeleteAjax", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded",
                        "RequestVerificationToken": token
                    },
                    body: "id=" + id
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById("skill-" + id).remove();
                        showToast("Skill deleted successfully ✔");
                    } else {
                        showToast("Delete failed ✖");
                    }
                })
                .catch(() => {
                    showToast("Something went wrong ✖");
                });
            });
        });
    </script>
}