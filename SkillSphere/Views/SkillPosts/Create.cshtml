@model SkillSphere.Models.SkillPost

@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Skill";

}

<div class="container py-5">

    <div class="card shadow-lg border-0 rounded-4 p-4 create-card">

        <div class="mb-4">

            <h2 class="fw-bold">
                Create New Skill
            </h2>

            <p class="text-muted">
                Share your skills with the community 🚀
            </p>

        </div>

        <form asp-action="Create">

            <!-- TITLE -->
            <div class="mb-4">

                <label asp-for="Title" class="form-label fw-semibold">
                    Skill Title
                </label>

                <input asp-for="Title"
                       class="form-control custom-input"
                       placeholder="Enter skill title" />

                <span asp-validation-for="Title"
                      class="text-danger">
                </span>

            </div>

            <!-- OFFER -->
            <div class="mb-4">

                <label asp-for="Offer"
                       class="form-label fw-semibold">

                    What Can You Offer?

                </label>

                <input asp-for="Offer"
                       class="form-control custom-input"
                       placeholder="Example: React, Photoshop..." />

                <span asp-validation-for="Offer"
                      class="text-danger">
                </span>

            </div>

            <!-- CATEGORY -->
            <div class="mb-4">

                <label asp-for="Category"
                       class="form-label fw-semibold">

                    Category

                </label>

                <select asp-for="Category"
                        class="form-select custom-select">

                    <option value="">Select Category</option>
                    <option value="Programming">Programming</option>
                    <option value="Design">Design</option>
                    <option value="Marketing">Marketing</option>
                    <option value="AI">AI</option>
                    <option value="Business">Business</option>

                </select>

                <span asp-validation-for="Category"
                      class="text-danger">
                </span>

            </div>

            <!-- TYPE -->
            <div class="mb-4">

                <label asp-for="Type"
                       class="form-label fw-semibold">

                    Type

                </label>

                <select asp-for="Type"
                        class="form-select custom-select">

                    <option value="">Select Type</option>
                    <option value="Learning">Learning</option>
                    <option value="Teaching">Teaching</option>

                </select>

                <span asp-validation-for="Type"
                      class="text-danger">
                </span>

            </div>

            <!-- DESCRIPTION -->
            <div class="mb-4">

                <label asp-for="Description"
                       class="form-label fw-semibold">

                    Description

                </label>

                <textarea asp-for="Description"
                          class="form-control custom-textarea"
                          rows="5"
                          placeholder="Describe your skill..."></textarea>

                <span asp-validation-for="Description"
                      class="text-danger">
                </span>

            </div>

            <!-- BUTTONS -->
            <div class="d-flex gap-3">

                <button type="submit"
                        class="save-btn">

                    Create Skill

                </button>

                <a asp-action="Index"
                       class="cancel-btn">

                    Back

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}