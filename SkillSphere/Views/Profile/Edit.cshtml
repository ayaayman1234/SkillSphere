@model SkillSphere.Models.ApplicationUser

<link rel="stylesheet" href="~/css/site.css" />

<div class="profile-page">
    <div class="container">

        <div class="profile-card">

            <h2>Edit Profile</h2>

            <p class="profile-bio mb-4">
                Update your personal information
            </p>

            <form asp-action="Edit" method="post">

                <div class="edit-grid">

                    <div class="edit-field">
                        <label>Full Name</label>
                        <input type="text" name="fullName"
                               value="@Model.FullName"
                               class="edit-input"
                               placeholder="Your full name" />
                    </div>

                    <div class="edit-field">
                        <label>Contact Number</label>
                        <input type="text" name="contactNumber"
                               value="@Model.ContactNumber"
                               class="edit-input"
                               placeholder="Your phone number" />
                    </div>

                    <div class="edit-field">
                        <label>Learning Skill</label>
                        <input type="text" name="learningSkill"
                               value="@Model.LearningSkill"
                               class="edit-input"
                               placeholder="What do you want to learn?" />
                    </div>

                    <div class="edit-field">
                        <label>Teaching Skill</label>
                        <input type="text" name="teachingSkill"
                               value="@Model.TeachingSkill"
                               class="edit-input"
                               placeholder="What can you teach?" />
                    </div>

                    <div class="edit-field">
                        <label>Available Hours</label>
                        <input type="text" name="availableHours"
                               value="@Model.AvailableHours"
                               class="edit-input"
                               placeholder="e.g. 9AM - 5PM" />
                    </div>

                    <div class="edit-field">
                        <label>Facebook Link</label>
                        <input type="text" name="facebookLink"
                               value="@Model.FacebookLink"
                               class="edit-input"
                               placeholder="https://facebook.com/..." />
                    </div>

                    <div class="edit-field">
                        <label>LinkedIn Link</label>
                        <input type="text" name="linkedInLink"
                               value="@Model.LinkedInLink"
                               class="edit-input"
                               placeholder="https://linkedin.com/in/..." />
                    </div>

                </div>

                <div class="edit-field mt-3">
                    <label>Bio</label>
                    <textarea name="bio"
                              class="edit-input"
                              rows="4"
                              placeholder="Tell us about yourself...">@Model.Bio</textarea>
                </div>

                <div class="edit-actions mt-4">

                    <button type="submit" class="btn-main">
                        <i class="fa-solid fa-floppy-disk me-2"></i>
                        Save Changes
                    </button>

                    <a asp-action="Index" class="btn-cancel">
                        Cancel
                    </a>

                </div>

            </form>

        </div>

    </div>
</div>