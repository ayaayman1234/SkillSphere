@model SkillSphere.Models.ApplicationUser

@{
    var avgRating = ViewBag.AverageRating ?? 0;
    var avg = (int)Math.Round(Convert.ToDouble(avgRating));
}

<link rel="stylesheet" href="~/css/site.css" />

<div class="profile-page">
    <div class="container">

        <!-- ================= PROFILE CARD ================= -->
        <div class="profile-card">

            <div class="profile-avatar">
                <span>
                    @(string.IsNullOrEmpty(Model.FullName)
                        ? "?"
                        : Model.FullName[0].ToString().ToUpper())
                </span>
            </div>

            <h2 class="mt-3">@Model.FullName</h2>

            <!-- ================= RATING ================= -->
            <div class="rating-summary mt-2">

                @if (ViewBag.RatingCount > 0)
                {
                    <div class="rating-stars-display">

                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fa-solid fa-star @(i <= avg ? "star-filled" : "star-empty")"></i>
                        }

                        <span class="rating-score">@ViewBag.AverageRating</span>

                        <span class="rating-count">
                            (@ViewBag.RatingCount reviews)
                        </span>

                    </div>
                }
                else
                {
                    <p class="no-rating">No ratings yet</p>
                }

            </div>

            <p class="profile-bio mt-3">
                @Model.Bio
            </p>

            <!-- ================= INFO ================= -->
            <div class="profile-info-grid mt-4">

                <div class="profile-info-item">
                    <i class="fa-solid fa-book-open"></i>
                    <div>
                        <span>Learning</span>
                        <p>@(Model.LearningSkill ?? "—")</p>
                    </div>
                </div>

                <div class="profile-info-item">
                    <i class="fa-solid fa-chalkboard-teacher"></i>
                    <div>
                        <span>Teaching</span>
                        <p>@(Model.TeachingSkill ?? "—")</p>
                    </div>
                </div>

                <div class="profile-info-item">
                    <i class="fa-solid fa-clock"></i>
                    <div>
                        <span>Available Hours</span>
                        <p>@(Model.AvailableHours ?? "—")</p>
                    </div>
                </div>

                <div class="profile-info-item">
                    <i class="fa-solid fa-phone"></i>
                    <div>
                        <span>Phone</span>
                        <p>@(Model.ContactNumber ?? "—")</p>
                    </div>
                </div>

            </div>

            <!-- ================= SOCIAL ================= -->
            <div class="social-links mt-4">

                @if (!string.IsNullOrEmpty(Model.LinkedInLink))
                {
                    <a href="@Model.LinkedInLink" target="_blank">
                        <i class="fa-brands fa-linkedin-in"></i>
                    </a>
                }

                @if (!string.IsNullOrEmpty(Model.FacebookLink))
                {
                    <a href="@Model.FacebookLink" target="_blank">
                        <i class="fa-brands fa-facebook-f"></i>
                    </a>
                }

            </div>

            <!-- ================= OWNER BUTTON ================= -->
            @if (ViewBag.IsOwner)
            {
                <div class="mt-4">
                    <a asp-action="Edit" class="btn-main">
                        <i class="fa-solid fa-pen me-2"></i>
                        Edit Profile
                    </a>
                </div>
            }

            <!-- ================= SWAP REQUEST ================= -->
            @if (!ViewBag.IsOwner)
            {
                <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">

                    <form asp-controller="SwapRequests"
                          asp-action="Send"
                          method="post">

                        <input type="hidden" name="toUserId" value="@ViewBag.ProfileUserId" />

                        <button type="submit" class="btn-main">
                            <i class="fa-solid fa-arrow-right-arrow-left me-2"></i>
                            Send Swap Request
                        </button>

                    </form>

                </div>
            }

        </div>

        <!-- ================= RATING SECTION ================= -->
        @if (!ViewBag.IsOwner)
        {
            <div class="rate-section mt-5">

                <h3>
                    @(ViewBag.AlreadyRated ? "Update Your Rating" : "Rate This Teacher")
                </h3>

                <form asp-controller="Rating"
                      asp-action="Submit"
                      method="post">

                    <input type="hidden" name="ratedUserId" value="@ViewBag.ProfileUserId" />

                    <div class="star-picker">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fa-solid fa-star rate-star" data-value="@i"></i>
                        }
                    </div>

                    <input type="hidden" name="score" id="scoreInput" value="0" />

                    <textarea name="comment"
                              class="form-control mt-3"
                              rows="3"
                              placeholder="Leave a comment (optional)..."></textarea>

                    <button type="submit" class="btn-main mt-3">
                        <i class="fa-solid fa-star me-2"></i>
                        Submit Rating
                    </button>

                </form>

            </div>
        }

        <!-- ================= REVIEWS ================= -->
        @if (ViewBag.RatingCount > 0)
        {
            <div class="reviews-section mt-5">

                <h3>Reviews</h3>

                <div class="reviews-list">

                    @foreach (var r in ViewBag.Ratings)
                    {
                        <div class="review-card">

                            <div class="review-header">
                                <strong>@r.Rater.FullName</strong>

                                <div class="review-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa-solid fa-star @(i <= r.Score ? "star-filled" : "star-empty")"></i>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(r.Comment))
                            {
                                <p class="review-comment">@r.Comment</p>
                            }

                            <small class="review-date">
                                @r.CreatedAt.ToShortDateString()
                            </small>

                        </div>
                    }

                </div>

            </div>
        }

    </div>
</div>

@section Scripts {
    <script>

        let selected = 0;

        const stars = document.querySelectorAll(".rate-star");
        const input = document.getElementById("scoreInput");

        stars.forEach(star => {

            star.addEventListener("mouseover", function () {
                let val = this.dataset.value;

                stars.forEach(s =>
                    s.classList.toggle("star-hover", s.dataset.value <= val)
                );
            });

            star.addEventListener("mouseout", function () {
                stars.forEach(s => {
                    s.classList.remove("star-hover");
                    s.classList.toggle("star-selected", s.dataset.value <= selected);
                });
            });

            star.addEventListener("click", function () {
                selected = this.dataset.value;
                if (input) input.value = selected;

                stars.forEach(s =>
                    s.classList.toggle("star-selected", s.dataset.value <= selected)
                );
            });

        });

    </script>
}