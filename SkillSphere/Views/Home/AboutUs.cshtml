@{
    ViewData["Title"] = "About Us";
}

<section class="about-page">
    <div class="container">

        <!-- HEADER -->

        <div class="about-header text-center">
            <span class="skills-tag">About SkillSphere</span>

            <h1 class="skills-main-title">
                Learn Skills From Real People
            </h1>

            <p class="skills-subtitle">
                SkillSphere connects learners and teachers together.
            </p>
        </div>

        <!-- ABOUT CARDS -->

        <div class="about-grid">

            <div class="about-card">

                <div class="about-icon">
                    <i class="fa-solid fa-users"></i>
                </div>

                <h3>Community</h3>

                <p>
                    Build a strong learning community where everyone grows together.
                </p>

            </div>

            <div class="about-card">

                <div class="about-icon">
                    <i class="fa-solid fa-code"></i>
                </div>

                <h3>Technology</h3>

                <p>
                    Learn modern tech skills easily from experienced professionals.
                </p>

            </div>

            <div class="about-card">

                <div class="about-icon">
                    <i class="fa-solid fa-star"></i>
                </div>

                <h3>Experience</h3>

                <p>
                    Rate and review teachers professionally to ensure quality.
                </p>

            </div>

        </div>

        <!-- PLATFORM STATS -->

        <div class="about-stats">

            <div class="stat-item">
                <h2>12+</h2>
                <p>Users</p>
            </div>

            <div class="stat-item">
                <h2>11+</h2>
                <p>Skills Shared</p>
            </div>

            <div class="stat-item">
                <h2>0+</h2>
                <p>Exchanges Done</p>
            </div>

            <div class="stat-item">
                <h2>100%</h2>
                <p>Free Learning</p>
            </div>

        </div>

    </div>
</section>